# 🖥️ AgenticOS: Professional Frontend Dashboard (Expert Tier)
# multi-stage build: node + nginx for high availability

# --- Stage 1: Intelligence Build ---
FROM node:20-alpine AS builder
WORKDIR /app

# Expert Efficiency: Install core dependencies
COPY packages/dashboard/package*.json ./
RUN npm ci --quiet

# Code Synthesis
COPY packages/dashboard ./
RUN npm run build

# --- Stage 2: Product Server (Production Nginx) ---
FROM nginx:stable-alpine
WORKDIR /usr/share/nginx/html

# Zero-Config Nginx setup (Custom logic injection)
COPY --from=builder /app/dist .
EXPOSE 80

# System Logic (Custom Nginx Routing for SPA)
RUN echo 'server { \
    listen 80; \
    location / { \
        root /usr/share/nginx/html; \
        index index.html index.htm; \
        try_files $uri $uri/ /index.html; \
    } \
}' > /etc/nginx/conf.d/default.conf

# Start Service
CMD ["nginx", "-g", "daemon off;"]
